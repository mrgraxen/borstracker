# Database
POSTGRES_USER=borstracker
POSTGRES_PASSWORD=borstracker
POSTGRES_DB=borstracker
DATABASE_URL=postgres://borstracker:borstracker@postgres:5432/borstracker?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# HTTP (no TLS) — app listens on this host port via Caddy
HTTP_PORT=8989

# Application
ENV=development
LOG_LEVEL=info
FRONTEND_ORIGIN=http://localhost:8989
COOKIE_SECURE=false
SESSION_MAX_AGE_DAYS=30
SESSION_COOKIE_NAME=session_id

# API
API_ADDR=:8080
API_RATE_LIMIT_PER_MIN=60

# Price fetcher
PRICE_FETCHER_ADDR=:8081
POLL_INTERVAL_SEC=5
YAHOO_MAX_CONCURRENCY=10
PRICE_CACHE_TTL_SEC=5

# Caddy — HTTP only in default setup (see deploy/caddy/Caddyfile)
# For HTTPS later: update Caddyfile and set COOKIE_SECURE=true + FRONTEND_ORIGIN=https://...
CADDY_DOMAIN=localhost
ACME_EMAIL=
